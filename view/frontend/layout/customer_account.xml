<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <!--
            Add a "My back-in-stock subscriptions" link to the customer
            account sidebar. ifconfig short-circuits on stores where the
            module is admin-disabled.
        -->
        <referenceBlock name="customer_account_navigation">
            <block class="Magento\Customer\Block\Account\SortLinkInterface"
                   name="customer-account-navigation-etechflow-bisn-link">
                <arguments>
                    <argument name="path" xsi:type="string">etechflow_bisn/customer/subscriptions</argument>
                    <argument name="label" xsi:type="string" translate="true">Back-in-Stock Subscriptions</argument>
                    <argument name="sortOrder" xsi:type="number">220</argument>
                </arguments>
            </block>
        </referenceBlock>
    </body>
</page>
