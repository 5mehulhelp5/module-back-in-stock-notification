<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <!--
            Render the "Notify me when back in stock" form directly under the
            Add-to-Cart button. The block self-suppresses via canDisplay() when:
              - BISN is disabled (license invalid OR admin toggle off)
              - OR the product is in stock (no need to subscribe)
            so the empty form never renders on a buyable product.

            Reference container: product.info.form  →  immediately after the
            Add-to-Cart form. This is the standard Magento product-form area
            and is also where Hyvä's product template renders.
        -->
        <referenceContainer name="product.info.form">
            <block class="ETechFlow\BackInStockNotification\Block\Product\NotifyMeForm"
                   name="etechflow.bisn.notify.form"
                   after="product.info.addtocart"
                   template="ETechFlow_BackInStockNotification::product/notify-me-form.phtml"
                   ifconfig="etechflow_bisn/general/enabled"/>
        </referenceContainer>
    </body>
</page>
