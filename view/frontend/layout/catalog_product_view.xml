<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <!--
            Render the "Notify me when back in stock" form in the product main
            info column (right side). We use product.info.main NOT product.info.form
            because Magento removes the add-to-cart form container entirely for
            out-of-stock products - which is exactly when our form must appear.

            The block self-suppresses via canDisplay() when:
              - BISN is disabled (license invalid OR admin toggle off), OR
              - the product is in stock (no need to subscribe).
        -->
        <referenceContainer name="product.info.main">
            <block class="ETechFlow\BackInStockNotification\Block\Product\NotifyMeForm"
                   name="etechflow.bisn.notify.form"
                   after="product.info.stock.sku"
                   template="ETechFlow_BackInStockNotification::product/notify-me-form.phtml"
                   ifconfig="etechflow_bisn/general/enabled"/>
        </referenceContainer>
    </body>
</page>