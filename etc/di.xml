<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <preference for="ETechFlow\BackInStockNotification\Api\Data\SubscriptionInterface"
                type="ETechFlow\BackInStockNotification\Model\Subscription"/>

    <preference for="ETechFlow\BackInStockNotification\Api\SubscriptionRepositoryInterface"
                type="ETechFlow\BackInStockNotification\Model\SubscriptionRepository"/>

    <type name="Magento\Framework\Console\CommandList">
        <arguments>
            <argument name="commands" xsi:type="array">
                <item name="etechflow_bisn_verify"
                      xsi:type="object">ETechFlow\BackInStockNotification\Console\Command\VerifyCommand</item>
            </argument>
        </arguments>
    </type>

    <!--
        Auto-link anonymous subs to newly-registered customers by email.
        See Plugin/Customer/AutoLinkSubscriptionsPlugin docblock for the
        full reasoning.
    -->
    <type name="Magento\Customer\Api\AccountManagementInterface">
        <plugin name="etechflow_bisn_auto_link_subscriptions"
                type="ETechFlow\BackInStockNotification\Plugin\Customer\AutoLinkSubscriptionsPlugin"
                sortOrder="100"/>
    </type>

    <!--
        Admin-grid data source. MUST live in GLOBAL etc/di.xml, NOT
        etc/adminhtml/di.xml. Magento merges a type's arguments across areas by
        array-union, so declaring CollectionFactory.collections in an area-scoped
        di.xml REPLACES (not merges) the global registry for that area, silently
        breaking every other grid registered in global etc/di.xml (product
        warnings, sales credit-memo/shipment, url-rewrite, every other eTechFlow
        grid). Always register grid data sources here in global scope.

        SearchResult uses Document items (which implement getCustomAttributes())
        so the UI DataProvider can render rows. mainTable + resourceModel point
        at our subscription table.
    -->
    <virtualType name="ETechFlowBisnSubscriptionGridSearchResult"
                 type="Magento\Framework\View\Element\UiComponent\DataProvider\SearchResult">
        <arguments>
            <argument name="mainTable" xsi:type="string">etechflow_bisn_subscription</argument>
            <argument name="resourceModel" xsi:type="string">ETechFlow\BackInStockNotification\Model\ResourceModel\Subscription</argument>
            <argument name="identifierName" xsi:type="string">subscription_id</argument>
        </arguments>
    </virtualType>

    <type name="Magento\Framework\View\Element\UiComponent\DataProvider\CollectionFactory">
        <arguments>
            <argument name="collections" xsi:type="array">
                <item name="etechflow_bisn_subscription_listing_data_source"
                      xsi:type="string">ETechFlowBisnSubscriptionGridSearchResult</item>
            </argument>
        </arguments>
    </type>
</config>
