<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <!--
        The subscription admin-grid data source (CollectionFactory.collections)
        and its ETechFlowBisnSubscriptionGridSearchResult virtualType were moved
        to the GLOBAL etc/di.xml on 2026-06-11.

        Reason: declaring CollectionFactory.collections in an area-scoped di.xml
        makes Magento's cross-area argument merge (array-union) REPLACE the
        global collections registry for that area, which silently broke every
        grid registered in global etc/di.xml (product warnings, sales
        credit-memo/shipment, url-rewrite, all other eTechFlow grids). Grid data
        sources must always be registered in global etc/di.xml. Do NOT re-add a
        CollectionFactory.collections argument in this file.
    -->
</config>
